# Detabot environment variables
# Copy to `.env` for local dev, or set these as Railway service variables in production.
# Do NOT commit a real `.env` — it is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
# Local XAMPP: driver=sqlite (no other DB vars needed).
# Railway: driver=mysql and use reference variables from the MySQL service, e.g.
#   DETABOT_DB_HOST=${{MySQL.MYSQLHOST}}
DETABOT_DB_DRIVER=mysql
DETABOT_DB_HOST=
DETABOT_DB_PORT=3306
DETABOT_DB_NAME=
DETABOT_DB_USER=
DETABOT_DB_PASS=

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# MAIL_PASSWORD must be a Gmail App Password (not the account password).
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Chatbot ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Public URL ───────────────────────────────────────────────────────────────
# Production: set to the Railway-generated domain after the first deploy.
APP_URL=https://<your-app>.up.railway.app/public
